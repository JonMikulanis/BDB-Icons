<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xsi:type="TaskPaneApp">

  <!-- ════════════════════════════════════════════════════
       STEP 1 — Replace YOUR-GITHUB-USERNAME and YOUR-REPO-NAME
       everywhere below with your actual values.
       ════════════════════════════════════════════════════ -->

  <Id>c7a3f1d2-84b0-4e2a-9f5c-3d1e7b6a0c8f</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>My Company</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>

  <DisplayName DefaultValue="Icon Library" />
  <Description DefaultValue="Insert company SVG icons directly into slides. Icons are stored inside the PowerPoint file." />

  <!-- Icon images are optional for sideloading — placeholder URLs work fine -->
  <IconUrl DefaultValue="https://YOUR-GITHUB-USERNAME.github.io/YOUR-REPO-NAME/icon-32.png" />
  <HighResolutionIconUrl DefaultValue="https://YOUR-GITHUB-USERNAME.github.io/YOUR-REPO-NAME/icon-80.png" />
  <SupportUrl DefaultValue="https://YOUR-GITHUB-USERNAME.github.io/YOUR-REPO-NAME" />

  <AppDomains>
    <AppDomain>https://YOUR-GITHUB-USERNAME.github.io</AppDomain>
  </AppDomains>

  <Hosts>
    <Host Name="Presentation" />
  </Hosts>

  <DefaultSettings>
    <!-- ════════════════════════════════════════════════════
         STEP 2 — This is the main URL PowerPoint will load.
         Replace the placeholders with your GitHub Pages URL.
         ════════════════════════════════════════════════════ -->
    <SourceLocation DefaultValue="https://YOUR-GITHUB-USERNAME.github.io/YOUR-REPO-NAME/taskpane.html" />
  </DefaultSettings>

  <Permissions>ReadWriteDocument</Permissions>

</OfficeApp>
